<idea-plugin>
    <extensions defaultExtensionNs="com.intellij">
        <completion.confidence
                order="first"
                language="Scala 3"
                implementationClass="katze.millij.reposearch.MillStringCompletionConfidence"
        />
        <completion.contributor
                language="Scala 3"
                order="first"
                implementationClass="katze.millij.reposearch.ScalaCompletionContributor"
        />
        <completion.contributor
                language="yaml"
                implementationClass="katze.millij.reposearch.YamlMavenCompletionContributor"
        />
    </extensions>
</idea-plugin>